# Copy to .env and fill in your values.
# Leave analytics vars unset in development so no tracking runs on local visits.

STRIPE_SECRET_KEY=
STRIPE_TEAM_PRODUCT_ID=
STRIPE_BUSINESS_PRODUCT_ID=

# Optional: set only in production (or when you want tracking). Unset = no scripts loaded.
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
