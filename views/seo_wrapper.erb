<!DOCTYPE html>
<html lang="<%= @locale.to_s.gsub('_', '-') %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @title || I18n.t('site.title', locale: @locale) %></title>
  <meta name="description" content="<%= @description || I18n.t('site.description', locale: @locale) %>">
  <link rel="canonical" href="<%= @canonical_url || 'https://www.bookrhub.com' %>">

  <!-- Resource Hints -->
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="preconnect" href="https://www.google-analytics.com">
  <link rel="preconnect" href="https://js.stripe.com">
  <link rel="dns-prefetch" href="https://my.bookrhub.com">

  <!-- Geo Tags -->
  <% if @geo_region %>
  <meta name="geo.region" content="<%= @geo_region %>">
  <% end %>
  <% if @geo_placename %>
  <meta name="geo.placename" content="<%= @geo_placename %>">
  <% end %>

  <!-- Favicon -->
  <link rel="icon" href="/images/icon.png" type="image/png">
  <link rel="icon" href="/images/icon.svg" type="image/svg+xml">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= @canonical_url || 'https://www.bookrhub.com' %>">
  <meta property="og:title" content="<%= @title || I18n.t('site.title', locale: @locale) %>">
  <meta property="og:description" content="<%= @description || I18n.t('site.description', locale: @locale) %>">
  <meta property="og:image" content="https://www.bookrhub.com/images/og-image.png">
  <meta property="og:locale" content="<%= @locale.to_s.gsub('_', '-') %>">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/styles.min.css?v=2.6.0">
  <link rel="stylesheet" href="/css/seo-layout.min.css?v=2.6.0">

  <% if ENV['GOOGLE_ANALYTICS_ID'].to_s.strip != '' %>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GOOGLE_ANALYTICS_ID'] %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= ENV['GOOGLE_ANALYTICS_ID'] %>');
  </script>
  <% end %>
</head>
<body>
  <!-- Scroll progress bar -->
  <div class="scroll-progress" id="scroll-progress" role="progressbar" aria-label="Page scroll progress"></div>

  <!-- Navigation -->
  <nav id="main-nav">
    <div class="nav-container">
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>" class="logo">
        <img src="https://www.bookrhub.com/images/isologo.svg" alt="BookrHub" class="isologo-image" width="140">
      </a>
      <div class="nav-links">
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#features"><%= I18n.t('navigation.features', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#why-us"><%= I18n.t('navigation.why_us', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#screenshots"><%= I18n.t('navigation.how_it_works', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#live-templates"><%= I18n.t('navigation.live_templates', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#pricing"><%= I18n.t('navigation.pricing', locale: @locale) %></a>
        <a href="https://my.bookrhub.com/session/new?locale=<%= @locale %>" class="text-sm font-medium hover:text-primary"><%= I18n.t('navigation.sign_in', locale: @locale) %></a>
        <a href="https://my.bookrhub.com/signup?locale=<%= @locale %>" class="cta-button"><%= I18n.t('navigation.get_started', locale: @locale) %></a>
      </div>
      <button class="mobile-menu-toggle" aria-label="Toggle menu" id="mobile-menu-toggle">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-links">
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>#features"><%= I18n.t('navigation.features', locale: @locale) %></a>
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>#why-us"><%= I18n.t('navigation.why_us', locale: @locale) %></a>
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>#screenshots"><%= I18n.t('navigation.how_it_works', locale: @locale) %></a>
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>#live-templates"><%= I18n.t('navigation.live_templates', locale: @locale) %></a>
      <a href="https://www.bookrhub.com/?locale=<%= @locale %>#pricing"><%= I18n.t('navigation.pricing', locale: @locale) %></a>
      <a href="https://my.bookrhub.com/session/new?locale=<%= @locale %>" class="text-sm font-medium"><%= I18n.t('navigation.sign_in', locale: @locale) %></a>
      <a href="https://my.bookrhub.com/signup?locale=<%= @locale %>" class="cta-button"><%= I18n.t('navigation.get_started', locale: @locale) %></a>
    </div>
  </div>

  <!-- Main Content -->
  <main>
    <%= @content %>
  </main>

  <!-- Floating CTA -->
  <div class="floating-cta" id="floating-cta" aria-hidden="true">
    <a href="https://my.bookrhub.com/signup?locale=<%= @locale %>" class="floating-cta-btn">
      <%= I18n.t('navigation.get_started', locale: @locale) %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
    </a>
  </div>

  <!-- Back to top -->
  <button type="button" class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
  </button>

  <!-- Internal Linking: Popular Resources (for SEO discovery) -->
  <section class="seo-internal-links">
    <div class="container">
      <div class="internal-links-grid">
        <div class="internal-links-col">
          <h3><%= @locale == :es ? 'Industrias' : 'Industries' %></h3>
          <ul>
            <li><a href="https://www.bookrhub.com/booking-system-for-barbers">Barbers</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-hair-salons">Hair Salons</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-nail-salons">Nail Salons</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-massage-spa">Massage & Spa</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-personal-trainers">Fitness</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-cleaners">Cleaners</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-beauty-salons">Beauty Salons</a></li>
          </ul>
        </div>
        <div class="internal-links-col">
          <h3><%= @locale == :es ? 'Comparaciones' : 'Comparisons' %></h3>
          <ul>
            <li><a href="https://www.bookrhub.com/vs-fresha">BookrHub vs Fresha</a></li>
            <li><a href="https://www.bookrhub.com/vs-setmore">BookrHub vs Setmore</a></li>
            <li><a href="https://www.bookrhub.com/vs-calendly">BookrHub vs Calendly</a></li>
            <li><a href="https://www.bookrhub.com/vs-timely">BookrHub vs Timely</a></li>
            <li><a href="https://www.bookrhub.com/vs-square">BookrHub vs Square</a></li>
            <li><a href="https://www.bookrhub.com/vs-acuity">BookrHub vs Acuity</a></li>
          </ul>
        </div>
        <div class="internal-links-col">
          <h3><%= @locale == :es ? 'Recursos' : 'Resources' %></h3>
          <ul>
            <li><a href="https://www.bookrhub.com/use-cases"><%= @locale == :es ? 'Casos de Uso' : 'Use Cases' %></a></li>
            <li><a href="https://www.bookrhub.com/all-booking-system-solutions"><%= @locale == :es ? 'Todas las Soluciones' : 'All Solutions' %></a></li>
            <li><a href="https://www.bookrhub.com/why-bookrhub"><%= @locale == :es ? 'Por Qué BookrHub' : 'Why BookrHub' %></a></li>
            <li><a href="https://www.bookrhub.com/best-free-booking-system"><%= @locale == :es ? 'Mejor Sistema Gratis' : 'Best Free System' %></a></li>
            <li><a href="https://www.bookrhub.com/free-booking"><%= @locale == :es ? 'Reservas Gratis' : 'Free Booking' %></a></li>
            <li><a href="https://www.bookrhub.com/no-shows-solution"><%= @locale == :es ? 'Reducir Inasistencias' : 'Reduce No-Shows' %></a></li>
          </ul>
        </div>
        <div class="internal-links-col">
          <h3><%= @locale == :es ? 'Ciudades' : 'Cities' %></h3>
          <ul>
            <li><a href="https://www.bookrhub.com/booking-system-for-barbers-in-auckland">Auckland</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-barbers-in-sydney">Sydney</a></li>
            <li><a href="https://www.bookrhub.com/booking-system-for-barbers-in-melbourne">Melbourne</a></li>
            <li><a href="https://www.bookrhub.com/es/sistema-de-turnos-para-barbers-en-buenos-aires">Buenos Aires</a></li>
            <li><a href="https://www.bookrhub.com/es/sistema-de-turnos-para-barbers-en-santiago">Santiago</a></li>
            <li><a href="https://www.bookrhub.com/es/sistema-de-turnos-para-barbers-en-montevideo">Montevideo</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-content">
      <div class="footer-brand">
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>" class="logo">
          <img src="https://www.bookrhub.com/images/isologo.svg" alt="BookrHub" class="isologo-image" width="120" loading="lazy">
        </a>
        <p><%= I18n.t('footer.description', locale: @locale) %></p>
      </div>
      <div class="footer-section">
        <h3><%= I18n.t('footer.product', locale: @locale) %></h3>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#features"><%= I18n.t('navigation.features', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#why-us"><%= I18n.t('navigation.why_us', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#live-templates"><%= I18n.t('navigation.live_templates', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/?locale=<%= @locale %>#pricing"><%= I18n.t('navigation.pricing', locale: @locale) %></a>
        <a href="https://my.bookrhub.com/session/new?locale=<%= @locale %>"><%= I18n.t('navigation.sign_in', locale: @locale) %></a>
        <a href="https://my.bookrhub.com/signup?locale=<%= @locale %>"><%= I18n.t('navigation.get_started', locale: @locale) %></a>
      </div>
      <div class="footer-section">
        <h3><%= I18n.t('footer.company', locale: @locale) %></h3>
        <a href="https://www.bookrhub.com/about"><%= I18n.t('footer.about_us', locale: @locale) %></a>
        <a href="https://blog.bookrhub.com"><%= I18n.t('footer.blog', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/contact"><%= I18n.t('footer.contact_us', locale: @locale) %></a>
      </div>
      <div class="footer-section">
        <h3><%= I18n.t('footer.support', locale: @locale) %></h3>
        <a href="https://support.bookrhub.com"><%= I18n.t('footer.help_center', locale: @locale) %></a>
        <a href="mailto:admin@bookrhub.com">admin@bookrhub.com</a>
      </div>
      <div class="footer-section">
        <h3><%= I18n.t('footer.legal', locale: @locale) %></h3>
        <a href="https://www.bookrhub.com/privacy"><%= I18n.t('footer.privacy_policy', locale: @locale) %></a>
        <a href="https://www.bookrhub.com/terms"><%= I18n.t('footer.terms_of_service', locale: @locale) %></a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 BookrHub | <%= I18n.t('footer.all_rights', locale: @locale) || 'All rights reserved.' %></p>
      <span style="display: flex; align-items: center; gap: 6px;"><%= I18n.t('footer.powered_by', locale: @locale) %> <a href="https://www.bookrhub.com" target="_blank" class="copyright-link" style="display: flex; align-items: center; gap: 6px;">BookrHub <img src="https://www.bookrhub.com/images/icon.svg" alt="BookrHub" style="height: 20px;" loading="lazy" decoding="async"></a></span>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>
