<!DOCTYPE html>
<html lang="<%= session[:locale] %>">
<head>
  <% if ENV['GOOGLE_TAG_MANAGER_ID'].to_s.strip != '' %>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','<%= ENV['GOOGLE_TAG_MANAGER_ID'] %>');</script>
  <!-- End Google Tag Manager -->
  <% end %>
  <link rel="stylesheet" href="/css/styles.css?v=2.5.0">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/images/icon.png" type="image/png">
  <link rel="icon" href="/images/icon.svg" type="image/svg+xml">
  <title><%= I18n.t('site.title') %></title>
  <meta name="description" content="<%= I18n.t('site.description') %>">
  <meta name="keywords" content="<%= I18n.t('site.keywords') %>">
  <meta name="author" content="<%= I18n.t('site.author') %>">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <%
    base_url = I18n.t('site.canonical_url')
    canonical_locale = params[:locale] || session[:locale]
    canonical_currency = params[:currency] || session[:currency]
    canonical_url = "#{base_url}/?locale=#{canonical_locale}&currency=#{canonical_currency}"
  %>
  <link rel="canonical" href="<%= canonical_url %>">

  <!-- Hreflang tags for multi-language SEO -->
  <%
    available_locales = I18n.available_locales
    locale_currency_map = @locale_currency_map || {}
    available_locales.each do |locale|
      locale_str = locale.to_s
      currency = locale_currency_map[locale_str] || locale_currency_map[locale_str.split('-').first] || 'USD'
  %>
  <link rel="alternate" hreflang="<%= locale_str %>" href="<%= base_url %>/?locale=<%= locale_str %>&currency=<%= currency %>">
  <% end %>
  <link rel="alternate" hreflang="x-default" href="<%= base_url %>/?locale=en&currency=USD">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= canonical_url %>">
  <meta property="og:title" content="<%= I18n.t('site.title') %>">
  <meta property="og:description" content="<%= I18n.t('site.description') %>">
  <meta property="og:image" content="https://bookrhub.com/images/og-preview.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="<%= I18n.t('site.title') %>">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="<%= canonical_url %>">
  <meta property="twitter:title" content="<%= I18n.t('site.title') %>">
  <meta property="twitter:description" content="<%= I18n.t('site.description') %>">
  <meta property="twitter:image" content="https://bookrhub.com/images/og-preview.jpg">
  <meta property="twitter:image:alt" content="<%= I18n.t('site.title') %>">

  <!-- Additional tags -->
  <meta property="og:site_name" content="BookrHub">
  <meta property="og:locale" content="<%= session[:locale] %>">
  <meta name="theme-color" content="#4f46e5">

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  <%= JSON.generate({
    "@context" => "https://schema.org",
    "@type" => "SoftwareApplication",
    "name" => "BookrHub - Online Booking System",
    "alternateName" => ["BookrHub Appointment System", "BookrHub Booking Software", "Fresha alternative", "SetMore alternative", "GetTimely alternative"],
    "applicationCategory" => "BusinessApplication",
    "operatingSystem" => "Web",
    "applicationSubCategory" => "Booking System",
    "offers" => {
      "@type" => "Offer",
      "price" => "0",
      "priceCurrency" => session[:currency]
    },
    "aggregateRating" => {
      "@type" => "AggregateRating",
      "ratingValue" => "4.8",
      "ratingCount" => "150"
    },
    "description" => I18n.t('site.description'),
    "url" => canonical_url,
    "screenshot" => "https://bookrhub.com/images/og-preview.jpg"
  }) %>
  </script>
  <script type="application/ld+json">
  <%= JSON.generate({
    "@context" => "https://schema.org",
    "@type" => "Organization",
    "name" => "BookrHub",
    "url" => canonical_url,
    "logo" => "https://bookrhub.com/images/isologo.svg",
    "description" => I18n.t('site.description'),
    "sameAs" => [
      "https://www.facebook.com/bookrhub",
      "https://www.twitter.com/bookrhub",
      "https://www.linkedin.com/company/bookrhub"
    ],
    "contactPoint" => {
      "@type" => "ContactPoint",
      "contactType" => "Customer Service",
      "email" => "admin@bookrhub.com"
    }
  }) %>
  </script>
  <%
    faq_main_entity = (1..8).map do |i|
      {
        "@type" => "Question",
        "name" => I18n.t("faq.question#{i}"),
        "acceptedAnswer" => {
          "@type" => "Answer",
          "text" => I18n.t("faq.answer#{i}")
        }
      }
    end
  %>
  <script type="application/ld+json">
  <%= JSON.generate({
    "@context" => "https://schema.org",
    "@type" => "FAQPage",
    "mainEntity" => faq_main_entity
  }) %>
  </script>
</head>
<body>
  <!-- Scroll progress bar -->
  <div class="scroll-progress" id="scroll-progress" role="progressbar" aria-label="Page scroll progress"></div>

  <% if ENV['GOOGLE_TAG_MANAGER_ID'].to_s.strip != '' %>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=<%= ENV['GOOGLE_TAG_MANAGER_ID'] %>"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <% end %>
  <% if ENV['GOOGLE_ANALYTICS_ID'].to_s.strip != '' %>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GOOGLE_ANALYTICS_ID'] %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= ENV['GOOGLE_ANALYTICS_ID'] %>');
  </script>
  <% end %>

  <!-- Navigation (gets .nav-scrolled when user scrolls) -->
  <nav id="main-nav">
    <div class="nav-container">
      <a href="https://bookrhub.com" class="logo">
        <img src="/images/isologo.svg" alt="BookrHub" class="isologo-image" width="140">
      </a>
      <div class="nav-links">
        <a href="#features"><%= I18n.t('navigation.features') %></a>
        <a href="#why-us"><%= I18n.t('navigation.why_us') %></a>
        <a href="#screenshots"><%= I18n.t('navigation.how_it_works') %></a>
        <a href="#live-templates"><%= I18n.t('navigation.live_templates') %></a>
        <a href="#pricing"><%= I18n.t('navigation.pricing') %></a>
        <a href="https://my.bookrhub.com/signup?locale=<%= session[:locale] %>&currency=<%= session[:currency] %>" class="cta-button"><%= I18n.t('navigation.get_started') %></a>
      </div>
      <button class="mobile-menu-toggle" aria-label="Toggle menu" id="mobile-menu-toggle">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-links">
      <a href="#features"><%= I18n.t('navigation.features') %></a>
      <a href="#why-us"><%= I18n.t('navigation.why_us') %></a>
      <a href="#screenshots"><%= I18n.t('navigation.how_it_works') %></a>
      <a href="#live-templates"><%= I18n.t('navigation.live_templates') %></a>
      <a href="#pricing"><%= I18n.t('navigation.pricing') %></a>
      <a href="https://my.bookrhub.com/signup?locale=<%= session[:locale] %>&currency=<%= session[:currency] %>" class="cta-button"><%= I18n.t('navigation.get_started') %></a>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <div class="social-proof-badge">
          <div class="proof-avatars">
            <span>M</span>
            <span>S</span>
            <span>A</span>
            <span>+</span>
          </div>
          <span class="proof-text"><strong>700+</strong> <%= I18n.t('hero.social_proof') %></span>
        </div>
        <p class="hero-stats"><span><%= I18n.t('hero.stats_free') %></span> · <span><%= I18n.t('hero.stats_setup') %></span> · <span><%= I18n.t('hero.stats_nocode') %></span></p>
        <h1><span class="gradient-text gradient-text-animate"><%= I18n.t('hero.headline') %></span></h1>
        <p class="hero-tagline"><%= I18n.t('hero.tagline') %></p>
        <p class="hero-subtitle"><%= I18n.t('site.hero_subtitle') %></p>
        <div class="hero-buttons">
          <a href="https://my.bookrhub.com/signup?locale=<%= session[:locale] %>&currency=<%= session[:currency] %>" class="btn-primary">
            <%= I18n.t('buttons.start_free_trial') %>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
          <a href="#screenshots" class="btn-secondary">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <%= I18n.t('buttons.watch_demo') %>
          </a>
        </div>
        <div class="trust-badges">
          <span class="trust-badge">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <%= I18n.t('hero.no_credit_card') %>
          </span>
          <span class="trust-badge">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <%= I18n.t('hero.setup_minutes') %>
          </span>
        </div>
      </div>
      <div class="hero-image">
        <!-- Phone mockup: visible on small devices -->
        <div class="hero-phone-mockup">
          <div class="iphone-mockup">
            <div class="iphone-screen">
              <img src="/gifs/iphone.gif" alt="BookrHub Demo" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
          </div>
        </div>
        <!-- Browser/website mockup: visible on large screens -->
        <div class="hero-website-mockup">
          <div class="browser-chrome">
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
            <span class="browser-url">barber.bookrhub.com</span>
          </div>
          <div class="browser-screen">
            <img src="/gifs/barber-landing.gif" alt="Premium landing page template — Barbershop" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos Section - Scrolling marquee -->
  <section class="logos-section" aria-label="<%= I18n.t('logos.trusted_by') %>">
    <div class="logos-container">
      <p class="logos-label"><%= I18n.t('logos.trusted_by') %></p>
      <div class="logos-marquee-wrap">
        <div class="logos-marquee">
          <span class="logo-item">Barber Studios</span>
          <span class="logo-item">Wellness Co.</span>
          <span class="logo-item">Nail Art Pro</span>
          <span class="logo-item">Fitness Hub</span>
          <span class="logo-item">Beauty Lane</span>
          <span class="logo-item">Barber Studios</span>
          <span class="logo-item">Wellness Co.</span>
          <span class="logo-item">Nail Art Pro</span>
          <span class="logo-item">Fitness Hub</span>
          <span class="logo-item">Beauty Lane</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Templates Section -->
  <section id="live-templates" class="live-templates">
    <div class="live-templates-container">
      <div class="section-header">
        <h2><%= I18n.t('live_templates.title') %></h2>
      </div>
      <div class="templates-grid">
        <div class="template-card template-card-featured animate-on-scroll">
          <div class="template-card-preview">
            <img src="/gifs/barber-landing.gif" alt="<%= I18n.t('live_templates.barber_card_title') %> template">
          </div>
          <div class="template-card-content">
            <h3><%= I18n.t('live_templates.barber_card_title') %></h3>
            <p><%= I18n.t('live_templates.barber_card_description') %></p>
            <a href="https://barber.bookrhub.com" target="_blank" rel="noopener noreferrer" class="btn-primary template-card-cta">
              <%= I18n.t('live_templates.view_live_demo') %>
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>
        </div>
        <!-- Placeholder cards for future templates (scale to 3-4) -->
        <div class="template-card template-card-coming animate-on-scroll stagger-1" aria-hidden="true">
          <div class="template-card-preview template-card-placeholder">
            <span>Coming soon</span>
          </div>
          <div class="template-card-content">
            <h3>More templates</h3>
            <p>Wellness, beauty & more.</p>
          </div>
        </div>
        <div class="template-card template-card-coming animate-on-scroll stagger-2" aria-hidden="true">
          <div class="template-card-preview template-card-placeholder">
            <span>Coming soon</span>
          </div>
          <div class="template-card-content">
            <h3>More templates</h3>
            <p>Wellness, beauty & more.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why BookrHub Section -->
